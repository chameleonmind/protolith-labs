---
import "../assets/styles/reset.scss";
import "../assets/styles/variables.scss";
import "../assets/styles/typography.scss";
import Layout from "../layouts/Layout.astro";
import StickyHeader from "../components/StickyHeader.astro";
import Footer from "../components/Footer.astro";
import PageContainer from "../components/PageContainer.astro";
import PlusBox from "../components/elements/PlusBox.astro";
import Button from "../components/elements/Button.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import emailDynamicsShot from "../assets/images/projects/email-dynamics-01.png";

type FeaturedProject = {
  name: string;
  role: string;
  years: string;
  domain: string;
  narrative: string[];
  outcome: string;
  href?: string;
  hrefLabel?: string;
  shot?: ImageMetadata;
  shotAlt?: string;
};

type LedgerEntry = {
  name: string;
  client: string;
  year: string;
  role: string;
  description: string;
  href?: string;
};

const featured: FeaturedProject[] = [
  {
    name: "Email Dynamics",
    role: "Founder & Engineer",
    years: "2025 — present",
    domain: "Email infrastructure",
    narrative: [
      "A platform that brings dynamic, server-rendered elements into emails — live inventory, countdowns, polls, personalised imagery — generated at the moment of open rather than at send time.",
      "I designed it, built it, and hope to ship it soon. The full stack: edge rendering layer, image generation pipeline, dashboard, billing, customer onboarding. Most decisions get made twice — once as the engineer building it, once as the user living with the consequences a week later.",
      "It serves teams in e-commerce, media, and SaaS who need email content that doesn't go stale between send and open.",
    ],
    outcome: "Bootstrapped from zero to a live product currently in live beta.",
    href: "https://email-dynamics.com",
    hrefLabel: "Visit Email Dynamics",
    shot: emailDynamicsShot,
    shotAlt: "Email Dynamics dashboard showing dynamic email element configuration.",
  },
  {
    name: "Generative AI image & video pipelines",
    role: "Lead engineer",
    years: "2026",
    domain: "AI infrastructure",
    narrative: [
      "Production pipelines for removing backgrounds from images, generating images and short-form video at scale — model orchestration, prompt management, queueing, asset storage, and a control plane that lets non-engineering operators run jobs without touching the underlying infrastructure.",
      "The challenge wasn't getting a single model to produce a good output. It was building the pipework around it: predictable cost, recoverable failures, retry semantics that don't double-bill, and a UI that makes the abstraction holdable.",
      "Worked closely with research and product to translate fast-moving model APIs into something operators could ship campaigns on without a daily standup with the platform team.",
    ],
    outcome: "Cut per-asset generation cost and time-to-output by an order of magnitude versus the team's earlier ad-hoc tooling.",
  },
  {
    name: "Used car sales platform",
    role: "Senior frontend engineer",
    years: "2025 — present",
    domain: "Marketplace",
    narrative: [
      "A consumer-facing marketplace for buying and selling used cars across a regional market. Search, listing flow, financing, dealer-side tooling, and the inventory backplane that kept tens of thousands of listings synchronised across channels.",
      "The frontend had to feel fast on phones in places with uneven mobile coverage, and survive partner data shapes that ranged from clean APIs to scraped CSVs.",
      "I was in charge of developing the various parts of the platform, as well as making sure that the team ships a cohesive, modern and fast front-end.",
    ],
    outcome: "Kept the front-end coherent and fast across parallel workstreams as the platform grew.",
  },
];

const ledger: LedgerEntry[] = [
  {
    name: "Bus ticket platform",
    client: "Regional transport operator",
    year: "2024",
    role: "Frontend engineer",
    description: "Booking flow, seat selection, and operator dashboard for a multi-route ticketing system.",
  },
  {
    name: "Internal Vue component library",
    client: "Product company",
    year: "2023 — present",
    role: "Library author",
    description: "Zero-dependency Vue component system covering forms, layout, navigation, and data display, used across the product suite.",
  },
  {
    name: "Anti-piracy network monitor",
    client: "Major regional telco network",
    year: "2018",
    role: "Full-stack engineer",
    description: "Real-time content fingerprinting and takedown workflow integrated into the carrier's network.",
  },
  {
    name: "Marketing site & customer apps",
    client: "Major regional telecom",
    year: "2019",
    role: "Senior frontend engineer",
    description: "Public marketing surface and self-service customer applications across web and mobile web.",
  },
  {
    name: "Queue management system",
    client: "Public-sector deployment",
    year: "2019",
    role: "Engineer",
    description: "End-to-end ticket and dispatch system for branch offices, kiosk to counter.",
  },
  {
    name: "Loyalty platform",
    client: "Major regional retailer",
    year: "2017",
    role: "Lead frontend engineer",
    description: "Multi-tenant points-and-rewards system serving hundreds of thousands of accounts.",
  },
];

const openSource: LedgerEntry[] = [
  {
    name: "nshot",
    client: "Open source",
    year: "Author",
    role: "github.com/chameleonmind/nshot",
    description: "A small utility, written and maintained in the open.",
    href: "https://github.com/chameleonmind/nshot",
  },
  {
    name: "Frame Fusion",
    client: "Open source",
    year: "Author",
    role: "github.com/chameleonmind/frame-fusion",
    description: "A side project explored and shipped publicly.",
    href: "https://github.com/chameleonmind/frame-fusion",
  },
  {
    name: "Turborepo",
    client: "Documentation contribution",
    year: "Contributor",
    role: "github.com/chameleonmind/turborepo",
    description: "A small documentation contribution to the Turborepo project.",
    href: "https://github.com/chameleonmind/turborepo",
  },
];
---

<Layout
  title="Selected Work | Protolith Labs"
  description="A selection of systems and platforms I've built — independently and embedded in product teams — across telco, AI, retail, and email infrastructure."
>
  <StickyHeader />
  <main>
    <PageContainer>
      <article class="selected-work">

        <section class="sw-intro">
          <PlusBox variant="inverted" class="sw-intro__heading">
            <h1 data-animate-entry>Selected Work</h1>
          </PlusBox>
          <PlusBox class="sw-intro__lede">
            <p data-animate-entry>
              A selection of systems and platforms I've built — independently and embedded in product
              teams — across telco, AI, retail, and email infrastructure.
            </p>
          </PlusBox>
        </section>

        <section class="sw-featured" aria-labelledby="featured-heading">
          <h2 id="featured-heading" class="sw-visually-hidden">Featured engagements</h2>

          {featured.map((project, index) => (
            <article class="sw-project" data-flip={index % 2 === 1 ? "true" : "false"}>
              <header class="sw-project__head" data-animate-entry>
                <h3 class="sw-project__name">{project.name}</h3>
                <p class="sw-project__meta">
                  <span>{project.role}</span>
                  <span aria-hidden="true">·</span>
                  <span>{project.years}</span>
                  <span aria-hidden="true">·</span>
                  <span>{project.domain}</span>
                </p>
              </header>

              <div class="sw-project__body">
                <figure class="sw-project__shot" data-empty={!project.shot} data-animate-entry>
                  {project.shot ? (
                    <Image
                      src={project.shot}
                      alt={project.shotAlt ?? `${project.name} screenshot`}
                      widths={[480, 720, 960, 1200]}
                      sizes="(min-width: 1024px) 540px, 100vw"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="sw-project__placeholder" aria-hidden="true">
                      <span class="sw-project__placeholder-name">{project.name}</span>
                      <span class="sw-project__placeholder-domain">{project.domain}</span>
                      <span class="sw-project__placeholder-rule" aria-hidden="true"></span>
                      <span class="sw-project__placeholder-note">Not shown publicly</span>
                    </div>
                  )}
                </figure>

                <div class="sw-project__text">
                  {project.narrative.map((paragraph) => <p data-animate-entry>{paragraph}</p>)}

                  <p class="sw-project__outcome" data-animate-entry>
                    <span class="sw-project__outcome-label">Outcome</span>
                    <span class="sw-project__outcome-text">{project.outcome}</span>
                  </p>

                  {project.href && (
                    <p class="sw-project__cta" data-animate-entry>
                      <a
                        class="sw-project__link"
                        href={project.href}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {project.hrefLabel ?? "Visit project"}
                        <span aria-hidden="true" class="sw-arrow">→</span>
                      </a>
                    </p>
                  )}
                </div>
              </div>
            </article>
          ))}
        </section>

        <section class="sw-ledger-section" aria-labelledby="ledger-heading">
          <header class="sw-ledger-section__head" data-animate-entry>
            <h2 id="ledger-heading">Other engagements</h2>
            <p>Client and product work, named where I can, anonymised where I can't.</p>
          </header>

          <ol class="sw-ledger" role="list">
            {ledger.map((entry) => (
              <li class="sw-ledger__row" data-animate-entry>
                <div class="sw-ledger__primary">
                  <span class="sw-ledger__name">{entry.name}</span>
                  <span class="sw-ledger__client">{entry.client}</span>
                  <span class="sw-ledger__year">{entry.year}</span>
                </div>
                <p class="sw-ledger__role">{entry.role}</p>
                <p class="sw-ledger__description">{entry.description}</p>
              </li>
            ))}
          </ol>
        </section>

        <section class="sw-ledger-section sw-ledger-section--oss" aria-labelledby="oss-heading">
          <header class="sw-ledger-section__head" data-animate-entry>
            <h2 id="oss-heading">Open source</h2>
            <p>Smaller, in the open. Linked to the source.</p>
          </header>

          <ol class="sw-ledger" role="list">
            {openSource.map((entry) => (
              <li class="sw-ledger__row" data-animate-entry>
                <div class="sw-ledger__primary">
                  {entry.href ? (
                    <a class="sw-ledger__name sw-ledger__name--link" href={entry.href} target="_blank" rel="noopener noreferrer">
                      {entry.name}
                    </a>
                  ) : (
                    <span class="sw-ledger__name">{entry.name}</span>
                  )}
                  <span class="sw-ledger__client">{entry.client}</span>
                  <span class="sw-ledger__year">{entry.year}</span>
                </div>
                <p class="sw-ledger__role">
                  {entry.href ? (
                    <a href={entry.href} target="_blank" rel="noopener noreferrer">{entry.role}</a>
                  ) : entry.role}
                </p>
                <p class="sw-ledger__description">{entry.description}</p>
              </li>
            ))}
          </ol>
        </section>

        <section class="sw-closing">
          <Button variant="text" href="/#contact">
            <span data-animate-entry>Discuss a project →</span>
          </Button>
        </section>

      </article>
    </PageContainer>
  </main>
  <Footer />
</Layout>

<script>
  import { animateEntry } from '../scripts/animate-entry'
  animateEntry({ container: '.sw-intro' })
  animateEntry({ container: '.sw-project', amount: 0.2, duration: 0.7, staggerDelay: 0.1, y: 40 })
  animateEntry({ container: '.sw-ledger-section', amount: 0.18, duration: 0.55, staggerDelay: 0.08, y: 28 })
  animateEntry({ container: '.sw-closing', amount: 0.45, duration: 0.5, staggerDelay: 0.08, y: 20 })
</script>

<style lang="scss">
  main {
    display: block;
    width: 100%;
    background-image: linear-gradient(90deg, var(--background-darker) 0%, var(--background-light) 50%, var(--background-darker) 100%);
    position: relative;
    min-height: 100vh;

    &::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100dvh;
      background:
        radial-gradient(circle at 20% 20%, var(--accent-color), transparent 50%),
        radial-gradient(circle at 80% 80%, var(--highlight-color), transparent 50%);
      background-blend-mode: screen;
      backdrop-filter: blur(20px);
      z-index: 0;
      opacity: 0.15;
    }

    > * {
      position: relative;
      z-index: 1;
    }
  }

  .selected-work {
    --sw-ease-out: cubic-bezier(0.22, 1, 0.36, 1);
    --sw-ease-soft: cubic-bezier(0.25, 1, 0.5, 1);
    padding: 6rem 1rem 5rem;
    max-width: 1200px;
    margin: 0 auto;

    @media (min-width: 1024px) {
      padding: 7rem 0 6rem;
    }
  }

  .sw-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Intro */
  .sw-intro {
    margin-bottom: 5rem;

    @media (min-width: 1024px) {
      margin-bottom: 7rem;
    }
  }

  .sw-intro__heading {
    text-align: center;

    h1 {
      margin: 0;
      padding: 0.5rem 0;
      font-size: clamp(2.25rem, 4vw + 1rem, 3rem);
      letter-spacing: -0.01em;
    }
  }

  .sw-intro__lede {
    margin-top: 1.5rem;
    text-align: center;

    p {
      max-width: 60ch;
      margin: 0 auto;
      padding: 1rem 1.5rem;
      color: var(--text-color-light);
      font-size: 1.125rem;
      line-height: 1.6;
    }

    @media (min-width: 1024px) {
      p {
        padding: 1.25rem 2rem;
        font-size: 1.1875rem;
      }
    }
  }

  /* Featured */
  .sw-featured {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-bottom: 6rem;

    @media (min-width: 1024px) {
      gap: 7rem;
      margin-bottom: 9rem;
      padding: 0 2rem;
    }
  }

  .sw-project {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
    isolation: isolate;

    &::before {
      content: "";
      position: absolute;
      right: 5%;
      bottom: -2rem;
      width: clamp(12rem, 26vw, 18rem);
      height: clamp(12rem, 26vw, 18rem);
      border-radius: 999px;
      background: radial-gradient(circle, rgba(255, 86, 65, 0.18) 0%, rgba(255, 86, 65, 0) 72%);
      filter: blur(48px);
      opacity: 0;
      transform: translate3d(0, 1rem, 0) scale(0.92);
      transition: opacity 0.7s var(--sw-ease-soft), transform 0.7s var(--sw-ease-soft);
      pointer-events: none;
      z-index: -1;
    }

    &[data-flip="true"]::before {
      right: auto;
      left: 5%;
      background: radial-gradient(circle, rgba(207, 1, 119, 0.14) 0%, rgba(207, 1, 119, 0) 74%);
    }

    &:hover::before,
    &:focus-within::before {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  .sw-project__head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--border-color);
    transition: transform 0.45s var(--sw-ease-out), border-color 0.35s ease;
  }

  .sw-project__name {
    margin: 0;
    font-size: clamp(1.5rem, 2vw + 0.75rem, 2rem);
    line-height: 1.2;
    color: var(--primary);
  }

  .sw-project__meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-color-light);
    letter-spacing: 0.01em;

    span[aria-hidden="true"] {
      opacity: 0.5;
    }
  }

  .sw-project__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;

    @media (min-width: 1024px) {
      grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
      gap: 3.5rem;
      align-items: start;
    }
  }

  .sw-project[data-flip="true"] .sw-project__shot {
    @media (min-width: 1024px) {
      order: 2;
    }
  }

  .sw-project[data-flip="true"] .sw-project__text {
    @media (min-width: 1024px) {
      order: 1;
    }
  }

  .sw-project__shot {
    margin: 0;
    position: relative;
    border-radius: calc(var(--radius) * 4);
    overflow: hidden;
    border: 1px solid var(--border-color);
    background-color: var(--background-darker);
    aspect-ratio: 4 / 3;
    will-change: transform;
    transition:
      transform 0.55s var(--sw-ease-soft),
      box-shadow 0.55s var(--sw-ease-soft),
      border-color 0.35s ease;

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.34), transparent 24%, transparent 68%, rgba(255, 86, 65, 0.12)),
        radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.28), transparent 32%);
      opacity: 0;
      transition: opacity 0.55s var(--sw-ease-soft);
      pointer-events: none;
    }

    img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.8s var(--sw-ease-soft);
    }

    &[data-empty="true"] {
      background-image: linear-gradient(180deg, var(--background-light), var(--background-darker));

      img {
        transform: none;
      }
    }
  }

  .sw-project:hover .sw-project__head,
  .sw-project:focus-within .sw-project__head {
    transform: translateY(-0.2rem);
    border-color: rgba(255, 86, 65, 0.22);
  }

  .sw-project:hover .sw-project__shot,
  .sw-project:focus-within .sw-project__shot {
    transform: translateY(-0.35rem) scale(1.01);
    box-shadow: 0 18px 42px rgba(7, 49, 106, 0.1);
    border-color: rgba(255, 86, 65, 0.22);
  }

  .sw-project:hover .sw-project__shot::after,
  .sw-project:focus-within .sw-project__shot::after {
    opacity: 1;
  }

  .sw-project:hover .sw-project__shot img,
  .sw-project:focus-within .sw-project__shot img {
    transform: scale(1.02);
  }

  .sw-project__shot[data-empty="true"]:hover,
  .sw-project__shot[data-empty="true"]:focus-within,
  .sw-project:hover .sw-project__shot[data-empty="true"],
  .sw-project:focus-within .sw-project__shot[data-empty="true"] {
    transform: translateY(-0.2rem);
    box-shadow: 0 16px 34px rgba(7, 49, 106, 0.08);
  }

  .sw-project__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.5rem 1.25rem;
    position: relative;
    gap: 0.5rem;
    transition: transform 0.55s var(--sw-ease-soft);
  }

  .sw-project__placeholder-name {
    font-family: "Funnel Display", sans-serif;
    font-weight: 700;
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.875rem);
    line-height: 1.15;
    color: var(--primary);
    max-width: 22ch;
    text-wrap-style: balance;
  }

  .sw-project__placeholder-domain {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-color-light);
    margin-top: 0.5rem;
  }

  .sw-project__placeholder-rule {
    display: block;
    width: 56px;
    height: 1px;
    margin: 0.875rem auto 0;
    border-top: 1px dashed var(--border-color);
    transform-origin: center;
    transition: transform 0.45s var(--sw-ease-out), border-color 0.35s ease;
  }

  .sw-project__placeholder-note {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-color-light);
    opacity: 0.55;
    transition: opacity 0.35s ease, transform 0.45s var(--sw-ease-out);
  }

  .sw-project:hover .sw-project__placeholder,
  .sw-project:focus-within .sw-project__placeholder {
    transform: translateY(-0.15rem);
  }

  .sw-project:hover .sw-project__placeholder-rule,
  .sw-project:focus-within .sw-project__placeholder-rule {
    transform: scaleX(1.2);
    border-color: rgba(255, 86, 65, 0.28);
  }

  .sw-project:hover .sw-project__placeholder-note,
  .sw-project:focus-within .sw-project__placeholder-note {
    opacity: 0.85;
    transform: translateY(-0.1rem);
  }

  .sw-project__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    p {
      margin: 0;
      font-size: 1.0625rem;
      line-height: 1.65;
      color: var(--text-color);
      max-width: 65ch;
    }

    @media (min-width: 1024px) {
      gap: 1.125rem;

      p {
        font-size: 1.0625rem;
      }
    }
  }

  .sw-project__outcome {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.75rem !important;
    padding-top: 1rem;
    border-top: 1px dashed var(--border-color);
  }

  .sw-project__outcome-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-text);
  }

  .sw-project__outcome-text {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--text-color);
  }

  .sw-project__cta {
    margin-top: 0.5rem !important;
  }

  .sw-project__link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    text-decoration: none;
    font-weight: 700;
    color: var(--text-color);
    position: relative;
    padding-bottom: 0.15rem;

    .sw-arrow {
      transition: transform 0.4s cubic-bezier(0.215, 0.61, 0.355, 1);
    }

    &::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: 0;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--accent-color), var(--accent-dark));
      transition: width 0.5s cubic-bezier(1, 0, 0, 1);
    }

    &:hover::after,
    &:focus-visible::after {
      width: 100%;
    }

    &:hover .sw-arrow,
    &:focus-visible .sw-arrow {
      transform: translateX(0.25rem);
    }

    &:focus-visible {
      outline: 2px solid var(--accent-color);
      outline-offset: 4px;
      border-radius: 2px;
    }
  }

  /* Ledger sections */
  .sw-ledger-section {
    margin-bottom: 5rem;

    &--oss {
      margin-bottom: 6rem;
    }
  }

  .sw-ledger-section__head {
    margin-bottom: 2.5rem;

    h2 {
      margin: 0 0 0.5rem;
      font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2rem);
      color: var(--primary);
    }

    p {
      margin: 0;
      color: var(--text-color-light);
      font-size: 1rem;
      max-width: 60ch;
    }
  }

  .sw-ledger {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px dashed var(--border-color);
  }

  .sw-ledger__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px dashed var(--border-color);
    transform-origin: left center;
    transition:
      background-color 0.3s ease,
