---
import Image from "astro/components/Image.astro";
import GradientBorder from "./elements/GradientBorder.astro";
import fullStackIcon from "../assets/images/full_stack.svg";
import frontEndIcon from "../assets/images/front_end.svg";
import designIcon from "../assets/images/design.svg";
import stabilizeIcon from "../assets/images/vibe_code_stabilization.svg";
import partnerIcon from "../assets/images/consulting.svg";

import ServiceOneBg from "../assets/images/service_glass_1.png";
import ServiceTwoBg from "../assets/images/service_glass_2.png";
import ServiceThreeBg from "../assets/images/service_glass_3.png";
import ServiceFourBg from "../assets/images/service_glass_4.png";
import ServiceFiveBg from "../assets/images/service_glass_5.png";
import PlusBox from "./elements/PlusBox.astro";

const services = [
  {
    id: "service-fullstack",
    ordinal: "01",
    title: "Full-stack product builds & MVPs",
    lead: "End-to-end delivery of web apps and MVPs: backend, frontend, and basic infrastructure. Perfect if you want a working product, not just mockups and promises.",
    bullets: [
      "Product discovery and scope definition (features, constraints, success criteria)",
      "Technical architecture and stack selection based on product goals",
      "Frontend development (Vue, React, Astro) and backend development (APIs, data models, integrations)",
      "Performance and scalability considerations from day one",
      "Launch support, documentation, and handoff",
    ],
    note: "*Engagements are tailored — not every project needs every service.",
    icon: fullStackIcon,
    bg: ServiceOneBg,
    alt: "Full-stack product builds & MVPs",
    iconAlt: "Full stack icon",
  },
  {
    id: "service-frontend",
    ordinal: "02",
    title: "Front-end consulting",
    lead: "Architecture reviews, refactors, and feature work for existing Vue or React projects. I help teams get unstuck, improve performance, and make the codebase less painful to work in.",
    bullets: [
      "Codebase audits and architectural reviews",
      "Vue 2 → Vue 3 or legacy React refactors and migrations",
      "Performance analysis and optimization",
      "Frontend tooling improvements (Vite, TypeScript, linting, testing)",
      "Feature development alongside your existing team",
      "Code reviews and technical mentorship for developers",
      "Establishing conventions, patterns, and documentation",
    ],
    note: "*Engagements are tailored — not every project needs every service.",
    icon: frontEndIcon,
    bg: ServiceTwoBg,
    alt: "Front-end consulting",
    iconAlt: "Front-end consulting icon",
  },
  {
    id: "service-design",
    ordinal: "03",
    title: "Product & UI design",
    lead: "Clean, functional product design with a developer’s brain behind it. Flows, UX, and UI that respect both users and the implementation.",
    bullets: [
      "Product and UX discovery workshops",
      "User flows and interaction design",
      "Wireframes and high-fidelity UI design",
      "Design systems and reusable component patterns",
      "UX improvements for existing products",
      "Accessibility-aware design decisions",
      "Design validation during implementation",
    ],
    note: "*Engagements are tailored — not every project needs every service.",
    icon: designIcon,
    bg: ServiceThreeBg,
    alt: "Product & UI design background",
    iconAlt: "Product & UI design icon",
  },
  {
    id: "service-stabilize",
    ordinal: "04",
    title: "Stabilizing fast-grown products",
    lead: "Whether it was vibe-coded or just started fast, some products are shipped early and quickly, and now feel fragile. I help teams stabilize, untangle, and evolve apps that grew without a clear structure.",
    bullets: [
      "Audits to identify structural, performance, and maintainability issues",
      "Untangling rushed or inconsistent logic",
      "Introducing clear architecture, patterns, and ownership boundaries",
      "Reducing technical debt in a controlled, prioritized way",
      "Creating a realistic stabilization and improvement roadmap",
    ],
    note: "*Sometimes the job isn’t adding new blocks — it’s making sure the existing ones actually hold.",
    icon: stabilizeIcon,
    bg: ServiceFourBg,
    alt: "Stabilizing fast-grown products background",
    iconAlt: "Stabilizing fast-grown products icon",
  },
  {
    id: "service-partner",
    ordinal: "05",
    title: "Long-term technical partner",
    lead: "For teams that need ongoing help but don’t want to hire full-time: code reviews, roadmap input, and hands-on development each month.",
    bullets: [
      "Ongoing development support",
      "Regular code reviews and architecture guidance",
      "Technical input for roadmap planning and prioritization",
      "Support during critical releases or refactors",
      "Acting as a senior engineer or fractional tech lead",
      "Knowledge sharing and team enablement",
    ],
    note: "*Engagements are tailored — not every project needs every service.",
    icon: partnerIcon,
    bg: ServiceFiveBg,
    alt: "Long-term technical partner background",
    iconAlt: "Long-term technical partner icon",
  },
];
---
<section id="services" class="solutions">
  <div class="solutions__head">
    <h2>What Protolith Labs can do for you</h2>
  </div>

  <div class="solutions__layout">
    <nav class="services-rail" aria-label="Services">
      <ol>
        {services.map((service, idx) => (
          <li>
            <a
              href={`#${service.id}`}
              class="services-rail__entry"
              data-rail-link
              data-target={service.id}
              aria-current={idx === 0 ? "true" : undefined}
            >
              <span class="services-rail__num">{service.ordinal}</span>
              <span class="services-rail__title">{service.title}</span>
              <span class="services-rail__bar" aria-hidden="true"></span>
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <div class="services-content">
      {services.map((service) => (
        <article id={service.id} class="service-block" data-service-block>
          <div class="service-block__ordinal" aria-hidden="true">{service.ordinal}</div>
          <h3 class="service-block__title">{service.title}</h3>
          <PlusBox variant="inverted" class="service-block__lead">
            <p>{service.lead}</p>
          </PlusBox>
          <div class="service-block__body">
            <ul class="service-block__bullets">
              {service.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
            <GradientBorder class="service-block__visual">
              <div class="hologram-card" data-icon-url={service.icon.src}>
                <Image src={service.bg} width={640} height={720} alt={service.alt} />
                <Image src={service.icon} class="icon" width="100" height="100" alt={service.iconAlt} />
              </div>
            </GradientBorder>
          </div>
          <small class="service-block__note">{service.note}</small>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const railLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>("[data-rail-link]")
  );
  const blocks = Array.from(
    document.querySelectorAll<HTMLElement>("[data-service-block]")
  );
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  if (railLinks.length && blocks.length) {
    const setActive = (id: string) => {
      railLinks.forEach((link) => {
        if (link.dataset.target === id) {
          link.setAttribute("aria-current", "true");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort(
            (a, b) =>
              (a.target as HTMLElement).getBoundingClientRect().top -
              (b.target as HTMLElement).getBoundingClientRect().top
          );

        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      {
        rootMargin: "-30% 0px -55% 0px",
        threshold: 0,
      }
    );

    blocks.forEach((block) => observer.observe(block));

    railLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const targetId = link.dataset.target;
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (!target) return;

        event.preventDefault();
        target.scrollIntoView({
          behavior: prefersReducedMotion ? "auto" : "smooth",
          block: "start",
        });
        setActive(targetId);
        history.replaceState(null, "", `#${targetId}`);
      });
    });
  }
</script>

<style lang="scss">
  .solutions {
    padding: 4rem 1rem 2rem;
    max-width: 80rem;
    margin: 0 auto;

    @media (min-width: 768px) {
      padding: 6rem 2rem 4rem;
    }
  }

  .solutions__head {
    margin-bottom: 3rem;

    h2 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--primary);
      letter-spacing: -0.01em;
      margin: 0;
      text-wrap-style: balance;

      @media (min-width: 768px) {
        font-size: 2.75rem;
      }
    }

    @media (min-width: 1024px) {
      max-width: 32rem;
      margin-bottom: 5rem;
    }
  }

  .solutions__layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;

    @media (min-width: 1024px) {
      display: grid;
      grid-template-columns: minmax(0, 32%) minmax(0, 1fr);
      column-gap: 4rem;
      align-items: start;
    }

    @media (min-width: 1280px) {
      grid-template-columns: minmax(0, 36%) minmax(0, 1fr);
      column-gap: 5rem;
    }
  }

  .services-rail {
    display: none;

    @media (min-width: 1024px) {
      display: block;
      position: sticky;
      top: 9rem;
      align-self: start;

      ol {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      li {
        border-top: 1px dashed var(--border-color);

        &:last-child {
          border-bottom: 1px dashed var(--border-color);
        }
      }
    }

    &__entry {
      display: grid;
      grid-template-columns: 2.5rem minmax(0, 1fr);
      column-gap: 1rem;
      align-items: baseline;
      padding: 1.25rem 0 1.25rem 1.25rem;
      text-decoration: none;
      color: var(--text-color);
      opacity: 0.4;
      transition: opacity 240ms cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
      cursor: pointer;
      outline: none;

      &:hover,
      &:focus-visible {
        opacity: 0.7;
      }

      &:focus-visible {
        box-shadow: 0 0 0 3px var(--accent-color-5);
        border-radius: var(--radius);
      }

      &[aria-current="true"] {
        opacity: 1;

        .services-rail__bar {
          opacity: 1;
        }
      }
    }

    &__num {
      font-family: "Manrope", sans-serif;
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--text-color-light);
    }

    &__title {
      font-family: "Funnel Display", sans-serif;
      font-size: 1.375rem;
      font-weight: 700;
      line-height: 1.2;
      color: var(--primary);

      @media (min-width: 1280px) {
        font-size: 1.5rem;
      }
    }

    &__bar {
      position: absolute;
      left: 0;
      top: 50%;
      width: 4px;
      height: 1.5rem;
      transform: translateY(-50%);
      background: linear-gradient(180deg, var(--accent-color), var(--accent-dark));
      opacity: 0;
      transition: opacity 240ms cubic-bezier(0.22, 1, 0.36, 1);
      border-radius: var(--radius);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-rail__entry,
    .services-rail__bar {
      transition: none;
    }
  }

  .services-content {
    display: flex;
    flex-direction: column;
  }

  .service-block {
    padding: 0 0 3rem;
    position: relative;

    & + & {
      border-top: 1px dashed var(--border-color);
      padding-top: 3rem;
    }

    @media (min-width: 768px) {
      padding-bottom: 5rem;

      & + & {
        padding-top: 5rem;
      }
    }

    @media (min-width: 1024px) {
      padding-bottom: 8rem;

      & + & {
        border-top: none;
        padding-top: 0;
      }

      &:last-child {
        padding-bottom: 2rem;
      }
    }

    &__ordinal {
      display: none;

      @media (min-width: 1024px) {
        display: block;
        font-family: "Manrope", sans-serif;
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: var(--text-color-light);
        margin-bottom: 0.75rem;
      }
    }

    &__title {
      font-family: "Funnel Display", sans-serif;
      font-size: 1.625rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--primary);
      margin: 0 0 1.5rem;
      text-wrap-style: balance;

      @media (min-width: 768px) {
        font-size: 2rem;
      }

      @media (min-width: 1280px) {
        font-size: 2.25rem;
      }
    }

    &__lead {
      margin-bottom: 2rem;

      :global(p) {
        font-size: 1rem;
        font-weight: 600;
        padding: 1rem 1.25rem;
        margin: 0;
        color: var(--text-color);

        @media (min-width: 768px) {
          font-size: 1.0625rem;
          padding: 1.25rem 1.5rem;
        }
      }
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      align-items: stretch;

      @media (min-width: 1024px) {
        flex-direction: row;
        gap: 2rem;
        align-items: flex-start;
      }
    }

    &__bullets {
      list-style-type: square;
      list-style-image: linear-gradient(45deg, var(--accent-color), var(--accent-dark));
      padding-left: 1.25rem;
      margin: 0;
      flex: 1 1 auto;

      @media (min-width: 1024px) {
        flex: 1 1 60%;
        max-width: 60%;
      }

      li {
        margin-bottom: 0.625rem;
        padding-left: 0.5rem;
        font-size: 0.9375rem;
        line-height: 1.55;

        @media (min-width: 768px) {
          font-size: 1rem;
        }

        @media (min-width: 1024px) {
          font-size: 1.0625rem;
        }
      }
    }

    &__visual {
      flex: 1 1 auto;

      @media (min-width: 1024px) {
        flex: 1 1 40%;
        max-width: 40%;
      }
    }

    .hologram-card {
      height: 18rem;
      min-height: unset;
      border-radius: calc(var(--radius) * 4);

      &::before {
        mix-blend-mode: screen;
      }

      @media (min-width: 1024px) {
        height: 22rem;
      }
    }

    &__note {
      display: block;
      margin-top: 1.5rem;
      color: var(--text-color-light);
      font-size: 0.8125rem;
      line-height: 1.5;
    }
  }
</style>
