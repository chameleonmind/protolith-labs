---
import PlusBox from "./elements/PlusBox.astro";

const fitSignals = [
  "There is a concrete product or operational problem behind the request.",
  "You want senior implementation judgment, not just extra ticket capacity.",
  "You can share enough context for us to protect scope, timeline, and quality.",
  "You prefer direct trade-off conversations over optimistic guesses.",
];

const pauseSignals = [
  "The priority is the lowest possible quote.",
  "The work needs to stay undefined until after kickoff.",
  "AI is the objective rather than a way to solve a real customer or business problem.",
];
---
<section class="fit-section" aria-labelledby="fit-heading">
  <div class="fit-section__header" data-animate-entry>
    <p class="fit-section__eyebrow">Project calibration</p>
    <h2 id="fit-heading">Is this the right kind of engagement?</h2>
    <p>
      Use this as a quick check before you reach out. The strongest work starts with a real business
      pressure, a decision-maker in the room, and room for honest trade-offs.
    </p>
  </div>

  <div class="fit-section__panel-shell" data-animate-entry>
    <PlusBox variant="all" class="fit-section__box">
      <div class="fit-section__guide">
        <div class="fit-section__primary">
          <p class="fit-section__label">Usually yes when...</p>
          <ul class="fit-section__list fit-section__list--primary">
            {fitSignals.map((signal, index) => (
              <li>
                <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
                <p>{signal}</p>
              </li>
            ))}
          </ul>
        </div>

        <aside class="fit-section__pause" aria-label="Reasons to pause before reaching out">
          <p class="fit-section__label">Worth pausing if...</p>
          <ul class="fit-section__list fit-section__list--pause">
            {pauseSignals.map((signal) => (
              <li>{signal}</li>
            ))}
          </ul>
          <p class="fit-section__note">
            If the yes side feels familiar and the right side is resolvable, the contact form is the next useful step.
          </p>
        </aside>
      </div>
    </PlusBox>
  </div>
</section>

<style lang="scss">
.fit-section {
  --fit-panel-padding: clamp(1.25rem, 3vw, 3rem);
  --fit-gap: clamp(1.5rem, 4vw, 4rem);

  padding: clamp(3rem, 8vw, 7rem) 0 clamp(4rem, 8vw, 7rem);

  &__header {
    display: grid;
    gap: 0.85rem;
    max-width: 760px;
    margin: 0 auto clamp(2rem, 5vw, 4rem);
    padding: 0 1.25rem;
    text-align: center;
  }

  &__eyebrow,
  &__label {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  &__eyebrow {
    color: var(--accent-color);
  }

  h2 {
    margin: 0;
    color: var(--primary);
    text-wrap-style: balance;
  }

  &__header > p:last-child {
    margin: 0 auto;
    max-width: 68ch;
    color: var(--text-color-light);
    text-wrap-style: pretty;
  }

  &__panel-shell {
    margin: 0 auto;
    width: calc(100% - 1.5rem);
    max-width: 1200px;
    border-radius: calc(var(--radius) * 4);
    background:
      linear-gradient(135deg, rgba(245, 247, 250, 0.92), rgba(236, 236, 239, 0.72)),
      radial-gradient(circle at 12% 18%, var(--accent-color-5), transparent 34%),
      radial-gradient(circle at 88% 82%, color-mix(in srgb, var(--primary) 8%, transparent), transparent 36%);

    @media (min-width: 768px) {
      width: 100%;
    }
  }

  :global(.fit-section__box) {
    display: block;
    padding: var(--fit-panel-padding);
    text-align: left;

    @media (min-width: 768px) {
      padding: 2rem;
    }
  }

  &__guide {
    display: grid;
    gap: var(--fit-gap);

    @media (min-width: 860px) {
      grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.72fr);
      align-items: stretch;
    }
  }

  &__primary,
  &__pause {
    min-width: 0;
  }

  &__primary {
    display: grid;
    align-content: start;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  &__pause {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1rem, 2.5vw, 1.5rem);
    border: 1px solid var(--border-color);
    border-radius: calc(var(--radius) * 4);
    background: color-mix(in srgb, var(--background-light) 62%, transparent);
  }

  &__label {
    color: var(--primary);
  }

  &__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  &__list--primary {
    display: grid;
    gap: 0;

    li {
      display: grid;
      grid-template-columns: 3.75rem minmax(0, 1fr);
      gap: clamp(1rem, 2vw, 1.5rem);
      align-items: start;
      padding: clamp(1.1rem, 2.4vw, 1.45rem) 0;
      border-top: 1px dashed var(--border-color);

      &:last-child {
        border-bottom: 1px dashed var(--border-color);
      }
    }

    span {
      font-family: "Funnel Display", sans-serif;
      font-size: clamp(1.75rem, 4vw, 3rem);
      font-weight: 900;
      line-height: 0.9;
      color: transparent;
      -webkit-text-stroke: 1px color-mix(in srgb, var(--primary) 45%, transparent);
    }

    p {
      margin: 0;
      max-width: 58ch;
      color: var(--text-color);
      font-size: clamp(1.05rem, 1.4vw, 1.25rem);
      line-height: 1.55;
      text-wrap-style: pretty;
    }
  }

  &__list--pause {
    display: grid;
    gap: 0.85rem;

    li {
      position: relative;
      padding-left: 1.25rem;
      color: var(--text-color-light);
      line-height: 1.55;
      text-wrap-style: pretty;

      &::before {
        content: "";
        position: absolute;
        top: 0.68em;
        left: 0;
        width: 0.45rem;
        height: 0.45rem;
        border: 1px solid var(--primary);
        border-radius: 50%;
        opacity: 0.6;
      }
    }
  }

  &__note {
    margin: auto 0 0;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
    color: var(--primary);
    font-weight: 700;
    line-height: 1.45;
  }

  @media (max-width: 520px) {
    &__header {
      text-align: left;
    }

    &__panel-shell {
      max-width: calc(100% - 1rem);
    }

    &__list--primary li {
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }
  }
}
</style>
