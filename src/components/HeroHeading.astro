---
const { class: className = "", ...rest } = Astro.props;
const lineOne = "Turn Raw Ideas Into";
const lineTwo = "Refined Products";
---

<h1 class={className} {...rest}>
  <span class="line-one">{lineOne}</span>
  <strong class="line-two">{lineTwo}</strong>
</h1>

<style lang="scss">
  h1 {
    padding: 1rem 2rem;
    line-height: 1.05;
    cursor: default;
    user-select: none;
    text-wrap-style: balance;

    .line-one {
      display: block;
      font-family: "Funnel Display", sans-serif;
      font-weight: 200;
      font-size: 2.75rem;
      letter-spacing: -0.01em;
      color: var(--text-color);
    }

    .line-two {
      display: block;
      font-family: "Funnel Display", sans-serif;
      font-weight: 800;
      font-size: 3.5rem;
      letter-spacing: -0.02em;
      color: var(--accent-text);
      margin-top: 0.15em;
    }

    @media (min-width: 1024px) {
      .line-one {
        font-size: 3.25rem;
      }

      .line-two {
        font-size: 3.6rem;
      }
    }
  }
</style>
